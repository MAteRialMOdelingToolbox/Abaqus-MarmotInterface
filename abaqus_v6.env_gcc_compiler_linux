import os

# -------------------------------------------------------------------
# FIND MARMOT INSTALL DIRECTORY
# -------------------------------------------------------------------
try:
    MarmotDir = os.environ['MARMOT_INSTALL_DIR']
except KeyError:
    print('Please set environment variable MARMOT_INSTALL_DIR to the directory containing Marmot')
    print('using default /usr/local')
    MarmotDir = '/usr/local'

# -------------------------------------------------------------------
# FIND MARMOT LIB DIRECTORY (lib vs lib64)
# -------------------------------------------------------------------
libdir = None
if 'MARMOT_INSTALL_LIBDIR' in os.environ:
    libdir = os.environ['MARMOT_INSTALL_LIBDIR']
else:
    # 1. Look for the actual compiled library to know for sure
    _possible_libdirs = ['lib64', 'lib']
    for _ld in _possible_libdirs:
        if os.path.exists(os.path.join(MarmotDir, _ld, 'libMarmot.so')) or \
           os.path.exists(os.path.join(MarmotDir, _ld, 'libMarmot.a')):
            libdir = _ld
            break
    
    # 2. Fallback: just check which directory exists (preferring lib64 for Rocky/RHEL)
    if not libdir:
        if os.path.exists(os.path.join(MarmotDir, 'lib64')):
            libdir = 'lib64'
        else:
            libdir = 'lib'
            
    # Cleanup search variables
    del _possible_libdirs
    try:
        del _ld
    except NameError:
        pass

# -------------------------------------------------------------------
# FIND EIGEN DIRECTORY
# -------------------------------------------------------------------
EigenDir = None
# 1. Check if the user specified an explicit path via environment variable
if 'EIGEN_DIR' in os.environ:
    EigenDir = os.environ['EIGEN_DIR']
else:
    # 2. Search common system installation paths
    _eigen_search_paths = [
        '/usr/local/include/eigen3',
        '/usr/include/eigen3',
        '/opt/local/include/eigen3',
        '/usr/local/include',
        '/usr/include'
    ]
    
    for _path in _eigen_search_paths:
        if os.path.exists(os.path.join(_path, 'Eigen', 'Core')):
            EigenDir = _path
            break

    # Cleanup search variables
    del _eigen_search_paths
    try:
        del _path
    except NameError:
        pass

# 3. Fallback if not found
if not EigenDir:
    raise EnvironmentError("Eigen library not found. Please set the EIGEN_DIR environment variable to the directory containing Eigen headers.")

# -------------------------------------------------------------------
# COMPILER AND LINKER FLAGS
# -------------------------------------------------------------------
fortCmd = "gfortran"

compile_fortran = [fortCmd,
                  '-c', '-cpp', '-fPIC','-extend-source',
                  '-DABQ_LNX86_64', '-DABQ_FORTRAN',
                  '-fautomatic',
                  '-mno-fma', 
                  '-fprotect-parens',
                  '-fstack-protector-strong',
                  '-msse3',
                  '-mavx', '-mavx2',
                  '-ffixed-line-length-none',
                   '-I%I', '%P']

# Use standard -std syntax for GCC
cppAdds = ['-std=c++2c', '-I'+os.path.join(MarmotDir, 'include'), "-O3", f"-I{EigenDir}"]

linkAdds = [
    '-L'+os.path.join(MarmotDir, libdir),
    '-Wl,-rpath,'+os.path.join(MarmotDir, libdir), 
    '-lMarmot',
]

link_sl = [fortCmd,
           '-fPIC', '-shared','-Wl,--add-needed', 
           '%E', '-Wl,-soname,%U', '-o', '%U', '%F', '%A', '%L', '%B',
           '-Wl,-Bdynamic'] + linkAdds

link_exe = [fortCmd,
            '-fPIC',
            '-Wl,-Bdynamic', '-Wl,--add-needed', '-o', '%J', '%F', '%M', '%L', '%B', '%O'] + linkAdds

# -------------------------------------------------------------------
# SAFELY APPEND C++ FLAGS
# -------------------------------------------------------------------
try:
    compile_cpp += cppAdds  
except NameError:
    compile_cpp = ['g++', '-c', '-fPIC', '-DABQ_LNX86_64'] + cppAdds

# -------------------------------------------------------------------
# ENVIRONMENT CLEANUP
# -------------------------------------------------------------------
# Clean up the namespace so Abaqus doesn't ingest temporary variables
del fortCmd
del cppAdds
del linkAdds
del libdir
del MarmotDir
del EigenDir
